\contentsline {figure}{\numberline {6.1}{\ignorespaces Consumo del sistema sin OBS en ejecución: 15\,\% de CPU global y 56\,\% de memoria.}}{67}{figure.caption.139}%
\contentsline {figure}{\numberline {6.2}{\ignorespaces OBS Studio activo sin ningún filtro de realidad aumentada: 1,4\,\% de CPU reportado por OBS y cadencia estable de 30\,/\,30 fotogramas por segundo.}}{67}{figure.caption.140}%
\contentsline {figure}{\numberline {6.3}{\ignorespaces Modo 3D con 1 filtro: 1,1\,\% de CPU y 168,9\,MB.}}{68}{figure.caption.142}%
\contentsline {figure}{\numberline {6.4}{\ignorespaces Modo 3D con 3 filtros: 2,2\,\% de CPU y 228,8\,MB.}}{68}{figure.caption.142}%
\contentsline {figure}{\numberline {6.5}{\ignorespaces Modo AR con 1 filtro: 12,3\,\% de CPU y 193,5\,MB, cadencia estable.}}{68}{figure.caption.144}%
\contentsline {figure}{\numberline {6.6}{\ignorespaces Modo AR con 3 filtros: cadencia degradada a 16,88\,/\,30 fotogramas por segundo.}}{68}{figure.caption.144}%
\contentsline {figure}{\numberline {6.7}{\ignorespaces Modo marcador de clasificación sin detección ArUco: 11,3\,\% de CPU.}}{69}{figure.caption.146}%
\contentsline {figure}{\numberline {6.8}{\ignorespaces Modo marcador de clasificación con detección ArUco activa: 12,4\,\% de CPU.}}{69}{figure.caption.146}%
\contentsline {figure}{\numberline {6.9}{\ignorespaces Modo información de equipo con detección ArUco: 14,3\,\% de CPU y 154,4\,MB, cadencia estable de 30\,/\,30.}}{69}{figure.caption.147}%
\contentsline {figure}{\numberline {6.10}{\ignorespaces Configuración mixta (1 marcador de clasificación + 2 información de equipo): OBS reporta 25,1\,\% de CPU.}}{69}{figure.caption.149}%
\contentsline {figure}{\numberline {6.11}{\ignorespaces Administrador de Tareas bajo la configuración mixta: 22,7\,\% de CPU y cadencia degradada a 16,45\,/\,30.}}{69}{figure.caption.149}%
